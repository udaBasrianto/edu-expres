<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Edu HSI Admin
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="bg-slate-50 text-slate-800">
    <div class="min-h-screen flex flex-row">
        <%- include('../partials/admin-sidebar', { active: 'analytics' }) %>
            <div class="flex-1 flex flex-col md:ml-64 bg-slate-50 min-h-screen">
                <%- include('../partials/admin-header') %>
                <main class="flex-1 p-6 md:p-8 overflow-y-auto">
                    <div class="mb-6">
                        <h1 class="text-2xl font-bold">Analytics</h1>
                        <p class="text-slate-500">Ringkasan metrik aplikasi.</p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                        <div class="bg-white p-6 rounded-2xl border border-slate-100">
                            <h3 class="text-sm text-slate-500">Total Users</h3>
                            <p class="text-3xl font-bold mt-1">
                                <%= stats.users %>
                            </p>
                        </div>
                        <div class="bg-white p-6 rounded-2xl border border-slate-100">
                            <h3 class="text-sm text-slate-500">Active Courses</h3>
                            <p class="text-3xl font-bold mt-1">
                                <%= stats.courses %>
                            </p>
                        </div>
                        <div class="bg-white p-6 rounded-2xl border border-slate-100">
                            <h3 class="text-sm text-slate-500">Materials</h3>
                            <p class="text-3xl font-bold mt-1">
                                <%= stats.materials %>
                            </p>
                        </div>
                        <div class="bg-white p-6 rounded-2xl border border-slate-100">
                            <h3 class="text-sm text-slate-500">Enrollments</h3>
                            <p class="text-3xl font-bold mt-1">
                                <%= stats.enrollments %>
                            </p>
                        </div>
                    </div>
                </main>
            </div>
    </div>
    <script>
    </script>
</body>

</html>