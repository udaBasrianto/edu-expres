<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Edu HSI Admin
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800">
    <div class="min-h-screen flex flex-row">
        <%- include('../partials/admin-sidebar', { active: 'quizzes' }) %>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col md:ml-64 bg-slate-50 min-h-screen">
                <%- include('../partials/admin-header') %>
                <main class="flex-1 p-6 md:p-8 overflow-y-auto">
                    <div class="mb-6 flex justify-between items-center">
                        <div>
                            <h1 class="text-2xl font-bold">Quizzes</h1>
                            <p class="text-slate-500">Manage quizzes and questions.</p>
                        </div>
                        <button onclick="document.getElementById('createQuizModal').classList.remove('hidden')"
                            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 4v16m8-8H4"></path>
                            </svg>
                            Create Quiz
                        </button>
                    </div>

                    <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead
                                    class="text-xs text-slate-500 uppercase bg-slate-50/50 border-b border-slate-100">
                                    <tr>
                                        <th class="px-6 py-4 font-medium">Title</th>
                                        <th class="px-6 py-4 font-medium">Description</th>
                                        <th class="px-6 py-4 font-medium">Duration</th>
                                        <th class="px-6 py-4 font-medium">Status</th>
                                        <th class="px-6 py-4 font-medium text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    <% quizzes.forEach(function(q){ %>
                                        <tr class="hover:bg-slate-50/80 transition-colors">
                                            <td class="px-6 py-4 font-medium text-slate-800">
                                                <%= q.title %>
                                            </td>
                                            <td class="px-6 py-4 text-slate-600 truncate max-w-xs">
                                                <%= q.description %>
                                            </td>
                                            <td class="px-6 py-4 text-slate-600">
                                                <%= q.duration_minutes %> mins
                                            </td>
                                            <td class="px-6 py-4 text-slate-600">
                                                <span
                                                    class="px-2 py-1 rounded text-xs font-bold <%= q.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700' %>">
                                                    <%= q.is_active ? 'Active' : 'Inactive' %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-right flex justify-end gap-2">
                                                <a href="/admin/quizzes/<%= q.id %>/questions"
                                                    class="text-blue-600 hover:text-blue-800 font-medium">Edit
                                                    Questions</a>
                                                <button
                                                    onclick="openEditQuizModal('<%= q.id %>', '<%= q.title %>', '<%= q.description %>', '<%= q.duration_minutes %>', '<%= q.is_active %>')"
                                                    class="text-indigo-600 hover:text-indigo-800 font-medium">Edit</button>
                                                <form action="/admin/quizzes/delete" method="POST"
                                                    onsubmit="return confirm('Are you sure?')" class="inline">
                                                    <input type="hidden" name="id" value="<%= q.id %>">
                                                    <button type="submit"
                                                        class="text-red-600 hover:text-red-800 font-medium">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% if(quizzes.length===0){ %>
                                                <tr>
                                                    <td colspan="5" class="px-6 py-8 text-center text-slate-400">No
                                                        quizzes found.</td>
                                                </tr>
                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </main>
            </div>
    </div>

    <!-- Create Quiz Modal -->
    <div id="createQuizModal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl max-w-lg w-full p-6">
            <h3 class="text-lg font-bold mb-4">Create New Quiz</h3>
            <form action="/admin/quizzes/create" method="POST">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Title</label>
                        <input type="text" name="title" required
                            class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                        <textarea name="description" rows="2"
                            class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"></textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Duration (minutes)</label>
                            <input type="number" name="duration_minutes" value="10"
                                class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
                            <select name="is_active"
                                class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="mt-6 flex justify-end gap-3">
                    <button type="button" onclick="document.getElementById('createQuizModal').classList.add('hidden')"
                        class="px-4 py-2 text-slate-600 hover:bg-slate-50 rounded-lg font-medium">Cancel</button>
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium">Create
                        Quiz</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Quiz Modal -->
    <div id="editQuizModal" class="fixed inset-0 bg-black/50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl max-w-lg w-full p-6">
            <h3 class="text-lg font-bold mb-4">Edit Quiz</h3>
            <form action="/admin/quizzes/update" method="POST">
                <input type="hidden" name="id" id="editQuizId">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Title</label>
                        <input type="text" name="title" id="editQuizTitle" required
                            class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                        <textarea name="description" id="editQuizDesc" rows="2"
                            class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"></textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Duration (minutes)</label>
                            <input type="number" name="duration_minutes" id="editQuizDuration"
                                class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
                            <select name="is_active" id="editQuizActive"
                                class="w-full rounded-lg border-slate-300 border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="mt-6 flex justify-end gap-3">
                    <button type="button" onclick="document.getElementById('editQuizModal').classList.add('hidden')"
                        class="px-4 py-2 text-slate-600 hover:bg-slate-50 rounded-lg font-medium">Cancel</button>
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium">Update
                        Quiz</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openEditQuizModal(id, title, description, duration, active) {
            document.getElementById('editQuizId').value = id;
            document.getElementById('editQuizTitle').value = title;
            document.getElementById('editQuizDesc').value = desc;
            document.getElementById('editQuizDuration').value = duration;
            document.getElementById('editQuizActive').value = active;
            document.getElementById('editQuizModal').classList.remove('hidden');
        }
    </script>
</body>

</html>