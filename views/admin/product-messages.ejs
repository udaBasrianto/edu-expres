<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Messages - Edu HSI Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800">
    <div class="min-h-screen flex flex-row">
        <%- include('../partials/admin-sidebar', { active: 'product-messages' }) %>
            <div class="flex-1 flex flex-col md:ml-64 bg-slate-50 min-h-screen">
                <%- include('../partials/admin-header') %>
                    <main class="flex-1 p-6 md:p-8 overflow-y-auto">
                        <div class="mb-8">
                            <h1 class="text-2xl font-bold text-slate-800">Product Messages</h1>
                            <p class="text-slate-500 mt-1">View customer inquiries about products</p>
                        </div>

                        <div
                            class="bg-white rounded-2xl shadow-[0_2px_10px_-3px_rgba(6,81,237,0.1)] border border-slate-100 overflow-hidden">
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-left">
                                    <thead
                                        class="text-xs text-slate-500 uppercase bg-slate-50/50 border-b border-slate-100">
                                        <tr>
                                            <th class="px-6 py-4 font-medium">User</th>
                                            <th class="px-6 py-4 font-medium">Product</th>
                                            <th class="px-6 py-4 font-medium">Message</th>
                                            <th class="px-6 py-4 font-medium">Status</th>
                                            <th class="px-6 py-4 font-medium">Date</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100">
                                        <% if (messages && messages.length> 0) { %>
                                            <% messages.forEach(function(m) { %>
                                                <tr class="hover:bg-slate-50/80 transition-colors">
                                                    <td class="px-6 py-4">
                                                        <div class="flex items-center gap-3">
                                                            <div
                                                                class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">
                                                                <%= m.User ? m.User.name.charAt(0) : '?' %>
                                                            </div>
                                                            <div>
                                                                <p class="font-medium text-slate-800">
                                                                    <%= m.User ? m.User.name : 'Unknown' %>
                                                                </p>
                                                                <p class="text-xs text-slate-500">
                                                                    <%= m.User ? m.User.email : '' %>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td class="px-6 py-4 text-slate-600">
                                                        <%= m.Product ? m.Product.name : '-' %>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <p class="text-slate-700 max-w-xs truncate">
                                                            <%= m.message %>
                                                        </p>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <span
                                                            class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= m.is_read ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800' %>">
                                                            <%= m.is_read ? 'Read' : 'Unread' %>
                                                        </span>
                                                    </td>
                                                    <td class="px-6 py-4 text-xs text-slate-500">
                                                        <%= new Date(m.created_at ||
                                                            m.createdAt).toLocaleDateString('id-ID') %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="5"
                                                                class="px-6 py-12 text-center text-slate-400">No
                                                                messages found.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
            </div>
    </div>
</body>

</html>