<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deposits - Edu HSI Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800">
    <div class="min-h-screen flex flex-row">
        <%- include('../partials/admin-sidebar', { active: 'deposits' }) %>
            <div class="flex-1 flex flex-col md:ml-64 bg-slate-50 min-h-screen">
                <%- include('../partials/admin-header') %>
                    <main class="flex-1 p-6 md:p-8 overflow-y-auto">
                        <div class="mb-8">
                            <h1 class="text-2xl font-bold text-slate-800">Deposits / Top Up</h1>
                            <p class="text-slate-500 mt-1">Review and manage user deposit requests</p>
                        </div>

                        <div
                            class="bg-white rounded-2xl shadow-[0_2px_10px_-3px_rgba(6,81,237,0.1)] border border-slate-100 overflow-hidden">
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm text-left">
                                    <thead
                                        class="text-xs text-slate-500 uppercase bg-slate-50/50 border-b border-slate-100">
                                        <tr>
                                            <th class="px-6 py-4 font-medium">#</th>
                                            <th class="px-6 py-4 font-medium">User</th>
                                            <th class="px-6 py-4 font-medium">Bank</th>
                                            <th class="px-6 py-4 font-medium">Amount</th>
                                            <th class="px-6 py-4 font-medium">Proof</th>
                                            <th class="px-6 py-4 font-medium">Status</th>
                                            <th class="px-6 py-4 font-medium">Date</th>
                                            <th class="px-6 py-4 font-medium text-right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100">
                                        <% if (deposits && deposits.length> 0) { %>
                                            <% deposits.forEach(function(d) { %>
                                                <tr class="hover:bg-slate-50/80 transition-colors">
                                                    <td class="px-6 py-4 font-mono text-xs text-slate-500">#<%= d.id %>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <p class="font-medium text-slate-800">
                                                            <%= d.User ? d.User.name : 'Unknown' %>
                                                        </p>
                                                        <p class="text-xs text-slate-500">
                                                            <%= d.User ? d.User.email : '' %>
                                                        </p>
                                                    </td>
                                                    <td class="px-6 py-4 text-slate-600">
                                                        <%= d.BankAccount ? d.BankAccount.bank_name : '-' %>
                                                    </td>
                                                    <td class="px-6 py-4 font-semibold text-slate-800">Rp <%=
                                                            Number(d.amount || 0).toLocaleString('id-ID') %>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <% if (d.proof_image) { %>
                                                            <a href="/uploads/<%= d.proof_image %>" target="_blank"
                                                                class="text-blue-600 hover:text-blue-800 text-xs font-medium">View</a>
                                                            <% } else { %><span class="text-slate-400 text-xs">No
                                                                    proof</span>
                                                                <% } %>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <span
                                                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= d.status === 'approved' ? 'bg-green-100 text-green-800' : d.status === 'rejected' ? 'bg-red-100 text-red-800' : 'bg-amber-100 text-amber-800' %>">
                                                            <%= d.status %>
                                                        </span>
                                                    </td>
                                                    <td class="px-6 py-4 text-xs text-slate-500">
                                                        <%= new Date(d.created_at ||
                                                            d.createdAt).toLocaleDateString('id-ID') %>
                                                    </td>
                                                    <td class="px-6 py-4 text-right">
                                                        <% if (d.status==='pending' ) { %>
                                                            <form action="/admin/deposits/approve" method="POST"
                                                                class="inline">
                                                                <input type="hidden" name="id" value="<%= d.id %>">
                                                                <button type="submit"
                                                                    class="text-green-600 hover:text-green-800 text-xs font-medium mr-2">Approve</button>
                                                            </form>
                                                            <form action="/admin/deposits/reject" method="POST"
                                                                class="inline"
                                                                onsubmit="return confirm('Reject this deposit?')">
                                                                <input type="hidden" name="id" value="<%= d.id %>">
                                                                <button type="submit"
                                                                    class="text-red-600 hover:text-red-800 text-xs font-medium">Reject</button>
                                                            </form>
                                                            <% } else { %>
                                                                <span class="text-slate-400 text-xs">—</span>
                                                                <% } %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="8"
                                                                class="px-6 py-12 text-center text-slate-400">No deposit
                                                                requests found.</td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </main>
            </div>
    </div>
</body>

</html>