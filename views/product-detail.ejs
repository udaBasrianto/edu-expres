<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= product.name %> - Detail Produk
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.3s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body class="bg-slate-50 min-h-screen pb-32">

    <!-- Modern Native Header -->
    <header class="bg-white/90 backdrop-blur-xl fixed top-0 left-0 right-0 z-50 border-b border-slate-100 px-5 h-16 flex items-center justify-between shadow-[0_1px_3px_0_rgba(0,0,0,0.02)] max-w-md mx-auto">
        <div class="flex items-center gap-4 min-w-0">
            <a href="/" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 border border-slate-100 active:scale-90 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
            </a>
            <h1 class="font-black text-sm text-slate-800 truncate tracking-tight">Detail Produk</h1>
        </div>
        <div class="relative">
            <a href="/?tab=cart" class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 border border-slate-100 active:scale-90 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z" />
                </svg>
                <span class="cart-badge absolute -top-1 -right-1 bg-red-500 text-white text-[9px] font-black w-4 h-4 rounded-full flex items-center justify-center hidden border-2 border-white shadow-sm">0</span>
            </a>
        </div>
    </header>

    <main class="max-w-md mx-auto pt-16">
        <!-- Product Image -->
        <div class="w-full aspect-square bg-slate-200 overflow-hidden relative">
            <% if (product.image) { %>
                <img src="<%= product.image.startsWith('http') ? product.image : '/uploads/' + product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover">
            <% } else { %>
                <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-24 h-24 text-slate-300">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                    </svg>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-2">Gambar Tidak Tersedia</span>
                </div>
            <% } %>
            <div class="absolute bottom-6 left-6">
                <span class="inline-block px-3 py-1 bg-white/90 backdrop-blur-md text-blue-600 text-[9px] font-black uppercase tracking-widest rounded-lg shadow-lg">Premium Product</span>
            </div>
        </div>

        <!-- Product Info Card -->
        <div class="px-5 -mt-8 relative z-10">
            <div class="bg-white rounded-[32px] shadow-xl shadow-blue-900/5 p-6 border border-slate-100 space-y-6">
                <div>
                    <h2 class="text-xl font-black text-slate-800 leading-tight tracking-tight mb-2">
                        <%= product.name %>
                    </h2>
                    <div class="flex items-center justify-between">
                        <p class="text-2xl font-black text-blue-900 tracking-tight">
                            Rp <%= Number(product.price || 0).toLocaleString('id-ID') %>
                        </p>
                        <div class="flex items-center gap-3">
                            <div class="flex items-center bg-amber-50 px-2 py-1 rounded-lg border border-amber-100">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-amber-500 mr-1">
                                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                                </svg>
                                <span class="text-[10px] font-black text-amber-700"><%= product.rating || '5.0' %></span>
                            </div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Terjual <%= product.sold_count || 0 %>+</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-3 pt-2">
                    <h3 class="font-black text-slate-800 text-sm tracking-tight flex items-center gap-2">
                        <span class="w-1.5 h-4 bg-blue-600 rounded-full"></span>
                        Deskripsi Produk
                    </h3>
                    <p class="text-slate-500 text-xs leading-relaxed font-medium whitespace-pre-line">
                        <%= product.description || 'Tidak ada deskripsi tersedia untuk produk ini.' %>
                    </p>
                </div>

                <% if (product.link) { %>
                    <a href="<%= product.link %>" target="_blank" class="flex items-center justify-between p-4 rounded-2xl bg-blue-50 border border-blue-100 group active:scale-[0.98] transition-all">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-blue-600 shadow-sm border border-blue-100">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-black text-blue-900 leading-none mb-1">Link Eksternal</p>
                                <p class="text-[9px] font-bold text-blue-400 uppercase tracking-tighter leading-none">Buka di Browser Baru</p>
                            </div>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 text-blue-300 group-hover:translate-x-1 transition-transform">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>
                <% } %>
            </div>
        </div>
    </main>

    <!-- Bottom Sticky Action Bar -->
    <div class="fixed bottom-0 left-0 right-0 max-w-md mx-auto bg-white/90 backdrop-blur-xl border-t border-slate-100 px-6 py-5 z-50 flex items-center gap-4 shadow-[0_-10px_30px_rgba(0,0,0,0.04)] safe-area-inset-bottom">
        <button onclick="document.getElementById('chat-modal').classList.remove('hidden')"
            class="w-14 h-14 rounded-2xl bg-emerald-50 text-emerald-600 border border-emerald-100 flex items-center justify-center active:scale-90 transition-all shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
        </button>
        <button id="add-to-cart-btn" class="flex-1 bg-blue-600 text-white h-14 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-blue-600/20 active:scale-[0.98] transition-all flex items-center justify-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
            <span>+ Keranjang</span>
        </button>
    </div>

    <!-- Chat Modal -->
    <div id="chat-modal" class="fixed inset-0 z-[60] flex items-center justify-center hidden bg-slate-900/60 backdrop-blur-sm px-5">
        <div class="bg-white rounded-[32px] shadow-2xl w-full max-w-sm relative animate-fade-in-up flex flex-col max-h-[80vh] overflow-hidden border border-slate-100">
            <div class="p-6 border-b border-slate-50 flex items-center justify-between">
                <div>
                    <h3 class="text-lg font-black text-slate-800 leading-none mb-1">Tanya Admin</h3>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-none">Respon Cepat & Ramah</p>
                </div>
                <button onclick="document.getElementById('chat-modal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 active:scale-90 transition-transform">&times;</button>
            </div>

            <!-- Chat History -->
            <div id="chat-history" class="flex-1 overflow-y-auto p-6 space-y-4 bg-slate-50/50">
                <% if (user) { %>
                    <% if (messages && messages.length> 0) { %>
                        <% messages.forEach(msg=> { %>
                            <div class="flex flex-col space-y-1">
                                <div class="bg-blue-600 text-white px-4 py-3 rounded-2xl rounded-tr-none max-w-[85%] self-end shadow-sm text-xs font-medium">
                                    <%= msg.message %>
                                </div>
                                <span class="text-[9px] font-bold text-slate-300 self-end text-right uppercase tracking-tighter">
                                    <%= new Date(msg.created_at).toLocaleTimeString('id-ID', { hour: '2-digit' , minute: '2-digit' }) %>
                                </span>

                                <% if (msg.reply) { %>
                                    <div class="bg-white border border-slate-100 text-slate-700 px-4 py-3 rounded-2xl rounded-tl-none max-w-[85%] self-start shadow-sm text-xs font-medium">
                                        <%= msg.reply %>
                                    </div>
                                    <span class="text-[9px] font-bold text-slate-300 self-start uppercase tracking-tighter">
                                        Admin • <%= msg.replied_at ? new Date(msg.replied_at).toLocaleTimeString('id-ID', { hour: '2-digit' , minute: '2-digit' }) : '' %>
                                    </span>
                                <% } %>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-10">
                            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 border border-slate-100 shadow-sm">
                                <svg class="w-8 h-8 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                            </div>
                            <p class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Belum ada pesan</p>
                        </div>
                    <% } %>
                <% } else { %>
                    <p class="text-center text-slate-400 py-10 text-[10px] font-black uppercase tracking-widest">Silakan login dahulu</p>
                <% } %>
            </div>

            <div class="p-6 bg-white border-t border-slate-50 space-y-4">
                <textarea id="chat-message" class="w-full bg-slate-50 border-none rounded-2xl py-4 px-5 text-xs font-medium placeholder:text-slate-400 focus:ring-2 focus:ring-blue-600/10 focus:bg-white transition-all shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)]" rows="2" placeholder="Tulis pesan Anda..."></textarea>
                <div class="flex gap-3">
                    <button id="send-chat-btn" class="flex-1 bg-blue-600 text-white font-black py-3 rounded-2xl uppercase tracking-widest shadow-lg shadow-blue-600/20 active:scale-95 transition-all text-[10px]">Kirim Pesan</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const PRODUCT_ID = <%= product.id %>;
        const IS_LOGGED_IN = <%= user ? 'true' : 'false' %>;

        // Update cart badge
        function updateCartBadge() {
            fetch('/cart/count')
                .then(res => res.json())
                .then(data => {
                    document.querySelectorAll('.cart-badge').forEach(el => {
                        el.innerText = data.count;
                        if (data.count > 0) el.classList.remove('hidden');
                        else el.classList.add('hidden');
                    });
                })
                .catch(() => { });
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateCartBadge();

            // Add to Cart
            const cartBtn = document.getElementById('add-to-cart-btn');
            cartBtn.addEventListener('click', async () => {
                if (!IS_LOGGED_IN) {
                    const confirmed = await confirmDialog('Login Diperlukan', 'Silakan login terlebih dahulu untuk menambahkan ke keranjang.', 'Login Sekarang');
                    if (confirmed) window.location.href = '/?tab=login';
                    return;
                }

                cartBtn.disabled = true;
                cartBtn.classList.add('opacity-75', 'cursor-not-allowed');

                fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ product_id: PRODUCT_ID, quantity: 1 })
                })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success !== false) {
                            updateCartBadge();
                            notify(data.message || 'Berhasil ditambahkan ke keranjang!', 'success');
                        } else {
                            notify(data.message || 'Gagal menambahkan ke keranjang.', 'error');
                        }
                    })
                    .catch(() => notify('Gagal menambahkan ke keranjang.', 'error'))
                    .finally(() => {
                        cartBtn.disabled = false;
                        cartBtn.classList.remove('opacity-75', 'cursor-not-allowed');
                    });
            });

            // Chat - Send Message  
            const sendBtn = document.getElementById('send-chat-btn');
            sendBtn.addEventListener('click', async () => {
                if (!IS_LOGGED_IN) {
                    const confirmed = await confirmDialog('Login Diperlukan', 'Silakan login terlebih dahulu untuk mengirim pesan.', 'Login Sekarang');
                    if (confirmed) window.location.href = '/?tab=login';
                    return;
                }

                const msg = document.getElementById('chat-message').value;
                if (!msg.trim()) { notify('Mohon isi pesan.', 'warning'); return; }

                sendBtn.disabled = true;
                sendBtn.innerText = 'Mengirim...';

                fetch('/product/message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ product_id: PRODUCT_ID, message: msg })
                })
                    .then(async res => {
                        if (res.status === 401) {
                            notify('Sesi Anda telah berakhir. Silakan login kembali.', 'warning');
                            window.location.href = '/?tab=login';
                            throw new Error('Unauthorized');
                        }
                        const data = await res.json().catch(() => ({}));
                        if (!res.ok) throw new Error(data.message || 'Gagal mengirim pesan.');
                        return data;
                    })
                    .then(data => {
                        notify(data.message || 'Pesan berhasil dikirim!', 'success');
                        document.getElementById('chat-modal').classList.add('hidden');
                        document.getElementById('chat-message').value = '';
                        // Add message to chat history
                        const history = document.getElementById('chat-history');
                        const emptyMsg = history.querySelector('.italic');
                        if (emptyMsg) emptyMsg.remove();
                        const div = document.createElement('div');
                        div.className = 'flex flex-col space-y-1';
                        div.innerHTML = `
                        <div class="bg-blue-100 text-blue-900 px-3 py-2 rounded-lg rounded-tr-none max-w-[85%] self-end ml-auto">
                            ${msg}
                        </div>
                        <span class="text-[10px] text-gray-400 self-end text-right">Anda • Baru saja</span>
                    `;
                        history.appendChild(div);
                        history.scrollTop = history.scrollHeight;
                    })
                    .catch(err => {
                        if (err.message !== 'Unauthorized') {
                            console.error(err);
                            notify(err.message || 'Gagal mengirim pesan.', 'error');
                        }
                    })
                    .finally(() => {
                        sendBtn.disabled = false;
                        sendBtn.innerText = 'Kirim';
                    });
            });
        });
    </script>
</body>

</html>