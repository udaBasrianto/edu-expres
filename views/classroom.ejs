<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.title %> - Kelas</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-50 h-screen flex flex-col overflow-hidden">

    <!-- Header -->
    <header class="bg-white shadow-sm z-20 flex-none relative">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="/?tab=home" class="p-2 -ml-2 text-gray-600 hover:bg-gray-100 rounded-full transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                </a>
                <h1 class="font-bold text-gray-900 text-lg line-clamp-1"><%= course.title %></h1>
            </div>
            <!-- Progress Info -->
            <div class="hidden md:flex items-center gap-2 text-sm">
                <span class="text-gray-500">Progress:</span>
                <span id="classroom-progress-text" class="font-bold text-blue-900"><%= completedIds.length %> / <%= materials.length %></span>
                <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div id="classroom-progress-bar" class="h-full bg-blue-900 transition-all duration-500" style="width: <%= (completedIds.length / materials.length) * 100 %>%"></div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Layout -->
    <div class="flex-1 flex flex-col lg:flex-row max-w-7xl mx-auto w-full overflow-hidden">
        
        <!-- Content Area (Top/Left) -->
        <main class="flex-1 overflow-y-auto bg-black lg:bg-gray-50 flex flex-col items-center p-0 lg:p-6">
            <div class="w-full max-w-5xl bg-white lg:rounded-xl overflow-hidden shadow-sm border border-gray-100 flex flex-col">
                <% if (currentMaterial) { %>
                    <div class="aspect-video bg-black w-full flex items-center justify-center relative group">
                        <% if (currentMaterial.type === 'video' && currentMaterial.media_url) { %>
                            <% if (currentMaterial.media_url.includes('youtube') || currentMaterial.media_url.includes('youtu.be')) { %>
                                <% 
                                    let videoId = '';
                                    if (currentMaterial.media_url.includes('v=')) {
                                        videoId = currentMaterial.media_url.split('v=')[1].split('&')[0];
                                    } else if (currentMaterial.media_url.includes('youtu.be/')) {
                                        videoId = currentMaterial.media_url.split('youtu.be/')[1].split('?')[0];
                                    }
                                %>
                                <iframe class="w-full h-full" src="https://www.youtube.com/embed/<%= videoId %>" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                            <% } else { %>
                                <video controls class="w-full h-full">
                                    <source src="<%= currentMaterial.media_url %>" type="video/mp4">
                                    Browser Anda tidak mendukung tag video.
                                </video>
                            <% } %>
                        <% } else { %>
                            <div class="text-white p-10 text-center">
                                <p class="text-lg font-bold mb-2"><%= currentMaterial.title %></p>
                                <p class="text-gray-400">Konten tipe <%= currentMaterial.type %> belum didukung preview langsung.</p>
                                <% if (currentMaterial.link) { %>
                                    <a href="<%= currentMaterial.link %>" target="_blank" class="mt-4 inline-block bg-blue-600 text-white px-6 py-2 rounded-full hover:bg-blue-700">Buka Materi</a>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                    <div class="p-6 bg-white">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4">
                            <div>
                                <h2 class="text-xl font-bold text-gray-900 mb-2"><%= currentMaterial.title %></h2>
                                <p class="text-sm text-gray-500">Materi <%= currentMaterial.order %> • <%= currentMaterial.duration || '-' %></p>
                            </div>
                            <button 
                                onclick="toggleComplete('<%= currentMaterial.id %>')" 
                                id="btn-complete-<%= currentMaterial.id %>"
                                class="<%= completedIds.includes(String(currentMaterial.id)) ? 'bg-green-100 text-green-700 hover:bg-green-200' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %> px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                                </svg>
                                <span id="text-complete-<%= currentMaterial.id %>"><%= completedIds.includes(String(currentMaterial.id)) ? 'Selesai' : 'Tandai Selesai' %></span>
                            </button>
                        </div>
                        
                        <!-- Navigation Buttons -->
                        <div class="flex justify-between items-center border-t border-gray-100 pt-4">
                            <% if (prevMaterial) { %>
                                <a href="/classroom/<%= course.id %>/<%= prevMaterial.id %>" class="flex items-center gap-2 text-gray-600 hover:text-blue-900 font-medium px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                    </svg>
                                    Sebelumnya
                                </a>
                            <% } else { %>
                                <div></div>
                            <% } %>

                            <% if (nextMaterial) { %>
                                <a href="/classroom/<%= course.id %>/<%= nextMaterial.id %>" class="flex items-center gap-2 text-gray-600 hover:text-blue-900 font-medium px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors">
                                    Selanjutnya
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                    </svg>
                                </a>
                            <% } else { %>
                                <a href="/?tab=home" class="flex items-center gap-2 text-blue-900 hover:text-blue-800 font-medium px-4 py-2 rounded-lg hover:bg-blue-50 transition-colors">
                                    Selesai Kursus
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% } else { %>
                    <div class="p-10 text-center bg-white">
                        <p class="text-gray-500">Belum ada materi di kursus ini.</p>
                    </div>
                <% } %>
            </div>
        </main>

        <!-- Sidebar / Playlist (Bottom/Right) -->
        <aside class="w-full lg:w-96 bg-white border-t lg:border-t-0 lg:border-l border-gray-200 flex-none h-1/3 lg:h-full flex flex-col z-10">
            <div class="p-4 border-b border-gray-100 bg-gray-50 flex-none">
                <h3 class="font-bold text-gray-900">Daftar Materi</h3>
                <p class="text-xs text-gray-500"><%= materials.length %> Materi</p>
            </div>
            <div class="flex-1 overflow-y-auto divide-y divide-gray-50">
                <% materials.forEach((material, index) => { %>
                    <a href="/classroom/<%= course.id %>/<%= material.id %>" class="block p-4 hover:bg-blue-50 transition-colors <%= (currentMaterial && currentMaterial.id == material.id) ? 'bg-blue-50 border-l-4 border-blue-900 pl-3' : 'pl-4' %>">
                        <div class="flex gap-3">
                            <div id="sidebar-icon-<%= material.id %>" class="flex-none w-8 h-8 rounded-full <%= (currentMaterial && currentMaterial.id == material.id) ? 'bg-blue-900 text-white' : (completedIds.includes(String(material.id)) ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-500') %> flex items-center justify-center text-xs font-bold">
                                <% if (completedIds.includes(String(material.id)) && (!currentMaterial || currentMaterial.id != material.id)) { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                                    </svg>
                                <% } else { %>
                                    <%= index + 1 %>
                                <% } %>
                            </div>
                            <div class="flex-1">
                                <h4 class="text-sm font-medium text-gray-900 line-clamp-2 <%= (currentMaterial && currentMaterial.id == material.id) ? 'text-blue-900' : '' %>">
                                    <%= material.title %>
                                </h4>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-xs text-gray-400 flex items-center gap-1">
                                        <% if (material.type === 'video') { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                                                <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
                                            </svg>
                                            Video
                                        <% } else if (material.type === 'quiz') { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                                            </svg>
                                            Kuis
                                        <% } else { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                                                <path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5zm2.25 8.5a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5z" clip-rule="evenodd" />
                                            </svg>
                                            Dokumen
                                        <% } %>
                                        • <%= material.duration || '0m' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        </aside>
    </div>

    <script>
        async function toggleComplete(materialId) {
            const btn = document.getElementById(`btn-complete-${materialId}`);
            const text = document.getElementById(`text-complete-${materialId}`);
            
            // Optimistic UI update
            const isCompleted = text.innerText === 'Selesai';
            
            try {
                const res = await fetch('/classroom/complete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ materialId })
                });
                const data = await res.json();
                
                if (data.success) {
                    const totalMaterials = <%= materials.length %>;
                    const progressText = document.getElementById('classroom-progress-text');
                    const progressBar = document.getElementById('classroom-progress-bar');
                    const sidebarIcon = document.getElementById(`sidebar-icon-${materialId}`);
                    
                    let currentCount = parseInt(progressText.innerText.split(' / ')[0]);

                    if (data.completed) {
                        btn.className = "bg-green-100 text-green-700 hover:bg-green-200 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2";
                        text.innerText = "Selesai";
                        currentCount++;
                        
                        // Update Sidebar Icon to checkmark
                        if (sidebarIcon && !sidebarIcon.classList.contains('bg-blue-900')) {
                            sidebarIcon.className = "flex-none w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs font-bold";
                            sidebarIcon.innerHTML = `
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                                </svg>
                            `;
                        }
                    } else {
                        btn.className = "bg-gray-100 text-gray-700 hover:bg-gray-200 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2";
                        text.innerText = "Tandai Selesai";
                        currentCount--;

                        // Update Sidebar Icon back to number
                        if (sidebarIcon && !sidebarIcon.classList.contains('bg-blue-900')) {
                            sidebarIcon.className = "flex-none w-8 h-8 rounded-full bg-gray-100 text-gray-500 flex items-center justify-center text-xs font-bold";
                            // Note: we don't have the original index here easily without re-rendering or storing it, 
                            // but we can try to find it from the DOM or just reload if it's too complex.
                            // For simplicity in this edit, let's just use the material's order or reload if needed.
                            // Actually, let's just update the count and progress bar for now.
                        }
                    }
                    
                    // Update Progress UI
                    progressText.innerText = `${currentCount} / ${totalMaterials}`;
                    progressBar.style.width = `${(currentCount / totalMaterials) * 100}%`;

                    // If we need the sidebar icon to be perfect, a reload might be safest for the "uncheck" case
                    // unless we want to store the index in a data attribute.
                    if (!data.completed) window.location.reload(); 
                }
            } catch (error) {
                console.error(error);
                notify('Gagal menyimpan progress', 'error');
            }
        }
    </script>
</body>
</html>
