<!-- SweetAlert2 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Modern Notification Helper for Admin
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true
    });

    function notify(message, icon = 'info') {
        if (icon === 'success') {
            Toast.fire({ icon: 'success', title: message });
        } else {
            Swal.fire({
                title: 'Admin System',
                text: message,
                icon: icon,
                confirmButtonColor: '#2563eb', // blue-600
                confirmButtonText: 'OK'
            });
        }
    }

    // Override default alert
    window.alert = (message) => notify(message);

    async function confirmDialog(title, text, confirmText = 'Ya, Lanjutkan') {
        const result = await Swal.fire({
            title: title,
            text: text,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#2563eb',
            cancelButtonColor: '#dc2626',
            confirmButtonText: confirmText,
            cancelButtonText: 'Batal'
        });
        return result.isConfirmed;
    }

    // Intercept default confirm calls for onsubmit forms
    document.addEventListener('submit', async (e) => {
        const form = e.target;
        const onsubmit = form.getAttribute('onsubmit');
        
        // Match both single and double quotes
        if (onsubmit && onsubmit.includes('confirm(') && !form.dataset.confirmed) {
            e.preventDefault();
            const match = onsubmit.match(/confirm\(['"](.+?)['"]\)/);
            const msg = match ? match[1] : 'Apakah Anda yakin?';
            
            const confirmed = await confirmDialog('Konfirmasi Admin', msg);
            if (confirmed) {
                form.dataset.confirmed = "true";
                form.submit();
            }
        }
    });

    // Mobile Sidebar Toggle Logic
    document.addEventListener('DOMContentLoaded', () => {
        const sidebar = document.getElementById('admin-sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        const toggleBtn = document.getElementById('mobileSidebarToggle');
        const closeBtn = document.getElementById('closeSidebar');

        if (toggleBtn && sidebar) {
            toggleBtn.onclick = (e) => {
                e.preventDefault();
                sidebar.classList.remove('-translate-x-full');
                if (overlay) overlay.classList.remove('hidden');
            };
        }

        if (closeBtn && sidebar) {
            closeBtn.onclick = () => {
                sidebar.classList.add('-translate-x-full');
                if (overlay) overlay.classList.add('hidden');
            };
        }

        if (overlay && sidebar) {
            overlay.onclick = () => {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            };
        }
    });
</script>

