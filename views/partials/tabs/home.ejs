<div id="view-home" class="tab-content fade-in bg-slate-50 min-h-screen">
    <!-- Modern Native Header -->
    <div class="sticky top-0 bg-white/90 backdrop-blur-xl z-30 px-5 pt-4 pb-3 shadow-[0_1px_3px_0_rgba(0,0,0,0.02)] border-b border-slate-100 md:hidden">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary/10 border-2 border-white shadow-sm flex items-center justify-center overflow-hidden">
                    <img src="https://ui-avatars.com/api/?name=<%= user ? user.name : 'Tamu' %>&background=<%= primaryColor.replace('#', '') %>&color=fff" class="w-full h-full object-cover" alt="Avatar">
                </div>
                <div>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider leading-none mb-1">Assalamualaikum,</p>
                    <h2 class="text-sm font-black text-slate-800 leading-none truncate max-w-[150px]"><%= user ? user.name : 'Tamu' %></h2>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <div class="bg-primary/5 px-3 py-1.5 rounded-full border border-primary/10 flex items-center gap-1.5 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-primary">
                        <path d="M12 7.5a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z" />
                        <path fill-rule="evenodd" d="M1.5 4.875C1.5 3.839 2.34 3 3.375 3h17.25c1.035 0 1.875.84 1.875 1.875v14.25c0 1.036-.84 1.875-1.875 1.875H3.375A1.875 1.875 0 0 1 1.5 19.125V4.875ZM11.25 12a.75.75 0 1 1 1.5 0 .75.75 0 0 1-1.5 0ZM9.75 8.625a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm7.5 0a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm-7.5 5.25a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm7.5 0a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-[11px] font-black text-primary tracking-tight">Rp <%= (user && user.balance) ? Number(user.balance).toLocaleString('id-ID') : '0' %></span>
                </div>
                <button class="w-9 h-9 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 border border-slate-100 active:scale-90 transition-transform relative">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                    </svg>
                    <span class="absolute top-2 right-2.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                </button>
            </div>
        </div>
        
        <!-- Native Search UI -->
        <div class="relative group">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-slate-400 group-focus-within:text-primary transition-colors">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
            </div>
            <input type="text" placeholder="Cari materi, kuis, atau artikel..." 
                class="w-full bg-slate-50 border-none rounded-2xl py-3.5 pl-11 pr-4 text-xs font-medium placeholder:text-slate-400 focus:ring-2 focus:ring-primary/10 focus:bg-white transition-all shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)]">
        </div>
    </div>

    <!-- Banner Slider (Edge to Edge Style) -->
    <section class="mt-4 px-5">
        <div id="home-slider" class="w-full h-64 md:h-[450px] rounded-[32px] overflow-hidden relative bg-slate-200 group shadow-xl shadow-primary/10">
            <% if (typeof blogPosts !== 'undefined' && blogPosts.length > 0) { %>
                <% blogPosts.slice(0, 5).forEach((post, index) => { %>
                    <div class="slider-item absolute inset-0 transition-all duration-1000 transform <%= index === 0 ? 'opacity-100 translate-x-0' : 'opacity-0 translate-x-full' %> z-10 overflow-hidden" data-index="<%= index %>">
                        <img src="<%= post.image && post.image.startsWith('http') ? post.image : (post.image ? '/uploads/' + post.image : '') %>" 
                             class="w-full h-full object-cover transform scale-105 group-hover:scale-100 transition-transform duration-[2000ms]" 
                             alt="<%= post.title %>"
                             onerror="this.onerror=null; this.src='https://via.placeholder.com/800x400?text=No+Image'">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10 z-20">
                            <div class="flex items-center gap-2 mb-2">
                                <% if (post.category) { %>
                                <span class="text-[9px] md:text-xs font-black text-white bg-primary px-2.5 py-1 md:px-4 md:py-1.5 rounded-lg uppercase tracking-widest shadow-lg shadow-primary/30">
                                    <%= post.category.name %>
                                </span>
                                <% } %>
                                <span class="text-[9px] md:text-xs font-bold text-white/70 tracking-widest uppercase">Baru</span>
                            </div>
                            <h3 class="text-white font-black text-base md:text-3xl line-clamp-2 leading-tight drop-shadow-md tracking-tight"><%= post.title %></h3>
                        </div>
                        <a href="/post/<%= post.slug %>" class="absolute inset-0 z-30"></a>
                    </div>
                <% }); %>

                <!-- Navigation Buttons (Desktop & Mobile) -->
                <div class="absolute inset-y-0 left-4 flex items-center z-30 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
                    <button onclick="prevSlide()" class="p-2.5 rounded-full bg-black/20 backdrop-blur-md border border-white/10 text-white hover:bg-black/40 transition-all active:scale-90 shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                        </svg>
                    </button>
                </div>
                <div class="absolute inset-y-0 right-4 flex items-center z-30 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
                    <button onclick="nextSlide()" class="p-2.5 rounded-full bg-black/20 backdrop-blur-md border border-white/10 text-white hover:bg-black/40 transition-all active:scale-90 shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                        </svg>
                    </button>
                </div>
<% } else { %>
                <div class="w-full h-full flex flex-col items-center justify-center text-slate-400 bg-slate-50">
                    <svg class="w-12 h-12 mb-3 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-300">Menunggu Konten...</span>
                </div>
            <% } %>
        </div>
    </section>

    <!-- Quick Actions (Native Icon Style) -->
    <section class="px-5 py-6">
        <div class="grid grid-cols-4 gap-4">
            <button onclick="switchTab('academy')" class="flex flex-col items-center gap-2 group">
                <div class="w-14 h-14 rounded-2xl bg-primary/5 border border-primary/10 flex items-center justify-center text-primary group-active:scale-90 transition-transform shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                    </svg>
                </div>
                <span class="text-[10px] font-black text-slate-700 tracking-tight uppercase">Akademi</span>
            </button>
            <button onclick="switchTab('quiz')" class="flex flex-col items-center gap-2 group">
                <div class="w-14 h-14 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-600 group-active:scale-90 transition-transform shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                    </svg>
                </div>
                <span class="text-[10px] font-black text-slate-700 tracking-tight uppercase">Kuis</span>
            </button>
            <button onclick="switchTab('blog')" class="flex flex-col items-center gap-2 group">
                <div class="w-14 h-14 rounded-2xl bg-orange-50 border border-orange-100 flex items-center justify-center text-orange-600 group-active:scale-90 transition-transform shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
                    </svg>
                </div>
                <span class="text-[10px] font-black text-slate-700 tracking-tight uppercase">Blog</span>
            </button>
            <button class="flex flex-col items-center gap-2 group">
                <div class="w-14 h-14 rounded-2xl bg-purple-50 border border-purple-100 flex items-center justify-center text-purple-600 group-active:scale-90 transition-transform shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75c0-1.245-.38-2.402-1.032-3.357m0 0a5.996 5.996 0 0 0-3.218 3.357c-.652.955-1.032 2.112-1.032 3.357m0 0v1.5h2.25" />
                    </svg>
                </div>
                <span class="text-[10px] font-black text-slate-700 tracking-tight uppercase">Sertifikat</span>
            </button>
        </div>
    </section>

    <!-- Native Stats Card (Integrated) -->
    <section class="px-5 pb-6">
        <div class="bg-primary rounded-[24px] p-5 shadow-xl shadow-primary/20 relative overflow-hidden flex items-center justify-between">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
            <div class="relative z-10">
                <p class="text-[10px] font-black opacity-60 text-white uppercase tracking-widest mb-3">Statistik Belajar</p>
                <div class="flex items-center gap-6">
                    <div>
                        <p class="text-2xl font-black text-white leading-none"><%= typeof stats !== 'undefined' ? stats.courses : 0 %></p>
                        <p class="text-[9px] font-bold opacity-60 text-white uppercase mt-1">Kursus</p>
                    </div>
                    <div class="w-[1px] h-8 bg-white/20"></div>
                    <div>
                        <p class="text-2xl font-black text-white leading-none"><%= typeof stats !== 'undefined' ? stats.quizzes : 0 %></p>
                        <p class="text-[9px] font-bold opacity-60 text-white uppercase mt-1">Kuis</p>
                    </div>
                </div>
            </div>
            <div class="relative z-10 bg-white/10 p-3 rounded-2xl border border-white/5 backdrop-blur-sm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 opacity-60 text-white">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 1 3 2.48Z" />
                    </svg>
            </div>
        </div>
    </section>

    <script>
        let homeSliderInterval;
        
        function initHomeSlider() {
            const slides = document.querySelectorAll('.slider-item');
            if (slides.length <= 1) return;
            
            // Clear existing interval if any
            if (homeSliderInterval) clearInterval(homeSliderInterval);
            
            homeSliderInterval = setInterval(() => {
                nextSlide();
            }, 5000);
        }

        function nextSlide() {
            const slides = document.querySelectorAll('.slider-item');
            const active = document.querySelector('.slider-item.opacity-100');
            if (!active || !slides.length) return;
            
            let nextIndex = parseInt(active.dataset.index) + 1;
            if (nextIndex >= slides.length) nextIndex = 0;
            
            goToSlide(nextIndex);
        }

        function prevSlide() {
            const slides = document.querySelectorAll('.slider-item');
            const active = document.querySelector('.slider-item.opacity-100');
            if (!active || !slides.length) return;
            
            let prevIndex = parseInt(active.dataset.index) - 1;
            if (prevIndex < 0) prevIndex = slides.length - 1;
            
            goToSlide(prevIndex);
        }
        
        function goToSlide(index) {
            const slides = document.querySelectorAll('.slider-item');
            
            if (!slides.length) return;
            
            slides.forEach(slide => {
                slide.classList.remove('opacity-100', 'z-10');
                slide.classList.add('opacity-0', 'z-0');
            });
            
            if (slides[index]) {
                slides[index].classList.remove('opacity-0', 'z-0');
                slides[index].classList.add('opacity-100', 'z-10');
            }
            
            // Reset timer on manual interaction
            if (homeSliderInterval) {
                clearInterval(homeSliderInterval);
                homeSliderInterval = setInterval(() => {
                    nextSlide();
                }, 5000);
            }
        }
        
        document.addEventListener('DOMContentLoaded', initHomeSlider);
    </script>

    <!-- Recommended Courses (Horizontal Scroll) -->
    <section class="py-2">
        <div class="px-5 flex items-center justify-between mb-4">
            <h3 class="font-black text-slate-800 text-base tracking-tight">Rekomendasi Kursus</h3>
            <button onclick="switchTab('academy')" class="text-[11px] font-black text-primary uppercase tracking-widest">Lihat Semua</button>
        </div>
        <div id="home-reco-courses" class="flex overflow-x-auto gap-4 px-5 pb-6 no-scrollbar scroll-smooth">
            <!-- Populated via JS -->
        </div>
    </section>

    <!-- Active Quizzes (Inbox Style) -->
    <section class="px-5 py-6 bg-white rounded-t-[32px] shadow-[0_-1px_10px_rgba(0,0,0,0.02)]">
        <div class="flex items-center justify-between mb-5">
            <h3 class="font-black text-slate-800 text-base tracking-tight">Kuis Terbaru</h3>
            <button onclick="switchTab('quiz')" class="text-[11px] font-black text-primary uppercase tracking-widest">Latihan</button>
        </div>
        <% if (quizzesJson && quizzesJson.length > 0) { %>
        <div class="space-y-4">
            <% quizzesJson.slice(0,3).forEach(function(quiz){ %>
            <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 flex items-center gap-4 active:bg-slate-100 transition-colors">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-black text-slate-800 text-sm truncate leading-none mb-1"><%= quiz.title %></p>
                    <p class="text-[11px] text-slate-400 truncate leading-none font-medium"><%= quiz.description || 'Uji kemampuan Anda hari ini' %></p>
                </div>
                <a href="/quiz/<%= quiz.id %>" class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-primary shadow-sm border border-slate-100">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                    </svg>
                </a>
            </div>
            <% }) %>
        </div>
        <% } else { %>
        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-100 text-center">
            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Kuis Belum Tersedia</p>
        </div>
        <% } %>
    </section>

    <!-- Leaderboard & Products (Compact Row) -->
    <div class="bg-white px-5 pb-8 grid grid-cols-1 gap-8">
        <!-- Leaderboard -->
        <section>
            <div class="flex items-center justify-between mb-5">
                <h3 class="font-black text-slate-800 text-base tracking-tight">Top Rank</h3>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Bulan Ini</span>
            </div>
            <% if (leaderboard && leaderboard.length > 0) { %>
            <div class="bg-slate-50 rounded-2xl p-2 border border-slate-100">
                <% leaderboard.slice(0,3).forEach(function(item, idx){ %>
                <div class="flex items-center justify-between p-3 <%= idx !== 2 ? 'border-b border-slate-200/50' : '' %>">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg <%= idx === 0 ? 'bg-amber-100 text-amber-700' : idx === 1 ? 'bg-slate-200 text-slate-700' : 'bg-orange-100 text-orange-700' %> flex items-center justify-center font-black text-xs shadow-sm"><%= idx + 1 %></div>
                        <div class="min-w-0">
                            <p class="font-black text-slate-800 text-xs truncate leading-none mb-1"><%= item.name %></p>
                            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter">Avg Score: <%= Math.round(item.avg_score) %>%</p>
                        </div>
                    </div>
                    <div class="flex flex-col items-end">
                        <span class="text-[10px] font-black text-primary"><%= item.attempts %> Sesi</span>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        </section>

        <!-- Products (Horizontal Scroll) -->
        <section>
            <div class="flex items-center justify-between mb-5">
                <h3 class="font-black text-slate-800 text-base tracking-tight">Produk Digital</h3>
                <button onclick="switchTab('academy')" class="text-[11px] font-black text-blue-600 uppercase tracking-widest">Toko</button>
            </div>
            <% if (products && products.length > 0) { %>
            <div class="flex overflow-x-auto gap-4 -mx-5 px-5 pb-4 no-scrollbar">
                <% products.forEach(function(p){ %>
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100 w-40 shrink-0 shadow-sm flex flex-col justify-between active:scale-95 transition-all cursor-pointer group" onclick="window.location.href='/product/<%= p.id %>'">
                    <div>
                        <div class="w-full h-24 rounded-xl mb-3 flex items-center justify-center overflow-hidden bg-slate-100 relative group">
                            <% if (p.image) { %>
                                <img src="<%= p.image.startsWith('http') ? p.image : '/uploads/' + p.image %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="<%= p.title %>">
                            <% } else { %>
                                <div class="w-full h-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white/20">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
                                    </svg>
                                </div>
                            <% } %>
                            <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        </div>
                        <h4 class="font-black text-slate-800 text-xs line-clamp-2 leading-tight mb-1 group-hover:text-primary transition-colors"><%= p.title %></h4>
                        <p class="text-[9px] text-slate-400 font-bold uppercase mb-2">E-Book & Video</p>
                    </div>
                    <div class="flex items-center justify-between mt-auto">
                        <span class="text-[11px] font-black text-primary">Rp <%= Number(p.price).toLocaleString('id-ID') %></span>
                        <button class="w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center shadow-md active:scale-90 transition-transform hover:rotate-90" 
                                onclick="event.stopPropagation(); addProductToCart(<%= p.id %>, '<%- p.title %>', <%= p.price %>)">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>
                        </button>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        </section>
    </div>

    <!-- My Courses (Native Card Style) -->
    <section class="px-5 py-8 bg-slate-50 pb-28">
        <div class="flex items-center justify-between mb-5">
            <h3 class="font-black text-slate-800 text-base tracking-tight">Kursus Saya</h3>
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest"><%= myCourses ? myCourses.length : 0 %> Materi</span>
        </div>
        <% if (myCourses && myCourses.length > 0) { %>
            <div class="grid grid-cols-1 gap-4">
                <% myCourses.forEach(course => { %>
                    <div class="bg-white p-4 rounded-[24px] shadow-sm border border-slate-100 flex gap-4 items-center">
                        <div class="w-16 h-16 rounded-2xl bg-primary flex items-center justify-center text-white text-xl font-black shrink-0 shadow-lg shadow-primary/10">
                            <%= course.title.charAt(0) %>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="font-black text-slate-800 text-sm truncate mb-1 leading-none"><%= course.title %></h4>
                            <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden mt-2">
                                <div class="bg-primary h-full w-[45%]" style="width: <%= Math.floor(Math.random() * 80) + 10 %>%"></div>
                            </div>
                            <div class="flex items-center justify-between mt-2">
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Progres: <%= Math.floor(Math.random() * 100) %>%</p>
                                <a href="/classroom/<%= course.id %>" class="text-[9px] font-black text-primary uppercase tracking-widest flex items-center gap-1">Lanjut <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-2 h-2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg></a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="bg-white p-10 rounded-[32px] shadow-sm border border-slate-100 text-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-slate-100">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-slate-300">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                    </svg>
                </div>
                <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-4">Belum Ada Kursus Aktif</p>
                <button onclick="switchTab('academy')" class="text-[11px] font-black bg-primary text-white px-6 py-3 rounded-full uppercase tracking-widest shadow-lg shadow-primary/20 active:scale-95 transition-transform">Mulai Belajar</button>
            </div>
        <% } %>
    </section>

<script>
document.addEventListener('DOMContentLoaded', () => {
    fetch('/courses').then(r => r.json()).then(list => {
        const container = document.getElementById('home-reco-courses');
        const items = list.slice(0, 6);
        items.forEach(course => {
            const div = document.createElement('div');
            div.className = 'bg-white p-4 rounded-[24px] shadow-lg shadow-slate-200/50 border border-slate-100 w-44 shrink-0 flex flex-col group active:scale-95 transition-transform';
            const badge = course.type === 'paid' ? 'Berbayar' : 'Gratis';
            const priceText = course.type === 'paid' ? new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(course.price) : 'Gratis';
            
            div.innerHTML = `
                <div class="w-full h-28 rounded-2xl bg-slate-100 mb-3 overflow-hidden relative">
                    <div class="absolute top-2 left-2 z-10">
                        <span class="text-[8px] font-black text-white ${course.type === 'paid' ? 'bg-amber-500' : 'bg-blue-500'} px-2 py-0.5 rounded-md uppercase tracking-tighter">${badge}</span>
                    </div>
                    <div class="w-full h-full flex items-center justify-center text-slate-300 font-black text-3xl bg-gradient-to-br from-slate-50 to-slate-100">
                        ${course.title.charAt(0)}
                    </div>
                </div>
                <h4 class="font-black text-slate-800 text-xs line-clamp-2 leading-tight mb-2 h-8">${course.title}</h4>
                <div class="flex items-center justify-between mt-auto">
                    <span class="text-[10px] font-black text-primary">${priceText}</span>
                    <button class="w-7 h-7 rounded-full bg-slate-50 text-primary flex items-center justify-center border border-slate-100 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    </button>
                </div>
            `;
            div.addEventListener('click', () => {
                if (typeof showCourseDetail === 'function') {
                    showCourseDetail(course.id);
                } else {
                    switchTab('academy');
                }
            });
            container.appendChild(div);
        });
    }).catch(() => {});
});

async function addProductToCart(id, title, price) {
    try {
        const res = await fetch('/cart/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ courseId: id, title, price })
        });
        const result = await res.json();
        if (result.success) {
            notify('Berhasil ditambahkan ke keranjang', 'success');
            if (typeof updateCartCount === 'function') updateCartCount();
        } else {
            notify(result.message || 'Gagal menambahkan ke keranjang', 'error');
        }
    } catch (e) {
        notify('Terjadi kesalahan koneksi', 'error');
    }
}
</script>
</div>
