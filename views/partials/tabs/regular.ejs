<!-- ======================= -->
<!-- TAB: REGULER (KUIS)     -->
<!-- ======================= -->
<div id="view-reguler" class="tab-content hidden fade-in">
    <!-- Header Reguler (Sticky) -->
    <div class="sticky top-0 bg-orange-600 z-10 px-4 py-3 shadow-md border-b border-orange-700 flex items-center justify-between text-white relative overflow-hidden">
        <div class="relative z-10">
            <h2 class="text-lg font-bold">Program Reguler</h2>
            <p class="text-orange-100 text-xs mt-0.5">Evaluasi pemahamanmu secara berkala.</p>
        </div>
        <div class="absolute right-[-10px] top-[-10px] w-20 h-20 bg-white opacity-10 rounded-full"></div>
    </div>

    <div class="p-4 space-y-6">
        <!-- BAGIAN: KUIS TERSEDIA -->
        <div>
            <div class="flex items-center justify-between mb-3 px-1">
                <h3 class="text-lg font-bold text-gray-800 flex items-center">
                    <span class="bg-blue-100 text-blue-600 p-1 rounded mr-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M11.983 1.907a.75.75 0 00-.491.13L3.6 7.573a.75.75 0 00-.1 1.128L11.5 16.7a.75.75 0 001.1-.1l8-8a.75.75 0 00-.1-1.128l-7.9-5.536a.75.75 0 00-.617-.03z" />
                        </svg>
                    </span>
                    Kuis Tersedia
                </h3>
            </div>

            <div class="space-y-3">
                <% if (typeof quizzesJson !=='undefined' && quizzesJson && quizzesJson.length> 0) { %>
                    <% quizzesJson.forEach(function(quiz) { %>
                        <% var borderColor=quiz.color==='green' ? 'bg-green-500' : quiz.color==='red' ? 'bg-red-500' :
                            quiz.color==='yellow' ? 'bg-yellow-500' : 'bg-blue-500' ; var badgeBg=quiz.color==='green'
                            ? 'bg-green-50 text-green-700 border-green-100' : quiz.color==='red'
                            ? 'bg-red-50 text-red-700 border-red-100' : quiz.color==='yellow'
                            ? 'bg-yellow-50 text-yellow-700 border-yellow-100'
                            : 'bg-blue-50 text-blue-700 border-blue-100' ; var isAttempted=typeof myAttempts
                            !=='undefined' && myAttempts && myAttempts.indexOf(quiz.id) !==-1; %>
                            <div
                                class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 hover:shadow-md transition-shadow relative overflow-hidden">
                                <div class="absolute left-0 top-0 bottom-0 w-1 <%= borderColor %>"></div>
                                <div class="flex justify-between items-start mb-2 pl-2">
                                    <div>
                                        <span
                                            class="inline-block px-2 py-0.5 rounded text-[10px] font-bold <%= badgeBg %> mb-1 border">
                                            <%= quiz.category || 'Umum' %>
                                        </span>
                                        <h4 class="font-bold text-gray-900 text-sm">
                                            <%= quiz.title %>
                                        </h4>
                                    </div>
                                    <div class="flex flex-col items-end">
                                        <span
                                            class="text-xs text-orange-600 font-bold bg-orange-50 px-2 py-1 rounded border border-orange-100">
                                            <%= quiz.duration_minutes || 30 %> Menit
                                        </span>
                                    </div>
                                </div>
                                <p class="text-xs text-gray-500 mb-3 pl-2">
                                    <%= quiz.description || '' %>
                                </p>
                                <div class="border-t border-gray-50 pt-3 flex justify-between items-center pl-2">
                                    <div class="flex items-center text-xs text-gray-500">
                                        <svg class="w-3 h-3 mr-1 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                                            <path
                                                d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm4.2 14.2L11 13V7h1.5v5.2l4.5 2.7-.8 1.3z" />
                                        </svg>
                                        Tipe: <span class="text-gray-700 font-medium ml-1 capitalize">
                                            <%= quiz.type || 'reguler' %>
                                        </span>
                                    </div>
                                    <% if (isAttempted) { %>
                                        <button disabled
                                            class="bg-green-100 text-green-700 text-xs font-bold px-4 py-2 rounded-lg border border-green-200 cursor-not-allowed flex items-center">
                                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24">
                                                <path
                                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                                            </svg>
                                            Selesai
                                        </button>
                                        <% } else { %>
                                            <button onclick="startQuiz(<%= quiz.id %>)"
                                                class="bg-blue-900 text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-blue-800 transition-colors shadow-sm active:scale-95 transform">
                                                Kerjakan
                                            </button>
                                            <% } %>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="text-center py-8 text-gray-400 text-sm">
                                        Belum ada kuis yang tersedia saat ini.
                                    </div>
                                    <% } %>
            </div>
        </div>

        <!-- BAGIAN: RIWAYAT / SELESAI -->
        <div class="opacity-75">
            <div class="flex items-center justify-between mb-3 px-1 mt-6">
                <h3 class="text-lg font-bold text-gray-600 flex items-center">
                    <span class="bg-gray-100 text-gray-500 p-1 rounded mr-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm4.2 14.2L11 13V7h1.5v5.2l4.5 2.7-.8 1.3z" />
                        </svg>
                    </span>
                    Riwayat Kuis
                </h3>
            </div>
            <div class="space-y-3">
                <% if (typeof quizHistory !=='undefined' && quizHistory && quizHistory.length> 0) { %>
                    <% quizHistory.forEach(function(attempt) { %>
                        <div onclick="openQuizResult(<%= attempt.id %>)"
                            class="bg-gray-50 rounded-xl border border-gray-100 p-4 cursor-pointer hover:bg-gray-100 transition-colors">
                            <div class="flex justify-between items-center">
                                <div>
                                    <h4 class="font-bold text-gray-700 text-sm line-through decoration-gray-400">
                                        <%= attempt.Quiz ? attempt.Quiz.title : 'Kuis' %>
                                    </h4>
                                    <p class="text-[10px] text-gray-400">Selesai: <%= attempt.completed_at ? new
                                            Date(attempt.completed_at).toLocaleDateString('id-ID',
                                            {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})
                                            : '-' %>
                                    </p>
                                    <span class="text-[10px] text-blue-600 font-bold underline mt-1 block">Lihat
                                        Detail</span>
                                </div>
                                <div class="text-right">
                                    <span
                                        class="block text-xl font-bold <%= attempt.score >= 70 ? 'text-green-600' : 'text-orange-500' %>">
                                        <%= attempt.score %>
                                    </span>
                                    <span
                                        class="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Nilai</span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                            <% } else { %>
                                <div class="text-center py-4 text-gray-400 text-xs italic">
                                    Belum ada riwayat kuis.
                                </div>
                                <% } %>
            </div>
        </div>

        <div class="text-center pt-2">
            <p class="text-xs text-gray-400">Semangat menuntut ilmu!</p>
        </div>
    </div>
</div>