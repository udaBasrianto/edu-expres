<div id="view-academy" class="tab-content hidden bg-slate-50 min-h-screen">
    <!-- Modern Native Header -->
    <div class="sticky top-0 bg-white/90 backdrop-blur-xl z-30 shadow-[0_1px_3px_0_rgba(0,0,0,0.02)] border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-5 pt-4 pb-3">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg md:text-xl font-black text-slate-800 tracking-tight">Akademi</h2>
                <div class="flex items-center gap-2">
                    <button class="w-9 h-9 md:w-10 md:h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 border border-slate-100 active:scale-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
                        </svg>
                    </button>
                </div>
            </div>
            
            <!-- Native Search UI -->
            <div class="relative group max-w-2xl">
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-slate-400 group-focus-within:text-blue-600 transition-colors">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>
                </div>
                <input type="text" id="academy-search" placeholder="Cari materi atau kursus..." 
                    class="w-full bg-slate-50 border-none rounded-2xl py-3.5 pl-11 pr-4 text-xs font-medium placeholder:text-slate-400 focus:ring-2 focus:ring-blue-600/10 focus:bg-white transition-all shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)]">
            </div>

            <!-- Filter Tabs (Horizontal) -->
            <div class="flex overflow-x-auto gap-2 mt-4 pb-1 no-scrollbar" id="academy-filters">
                <button onclick="filterAcademy('all', this)" class="filter-btn px-4 py-2 rounded-xl bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest whitespace-nowrap shadow-lg shadow-blue-600/20 transition-all">Semua</button>
                <button onclick="filterAcademy('free', this)" class="filter-btn px-4 py-2 rounded-xl bg-white text-slate-400 text-[10px] font-black uppercase tracking-widest whitespace-nowrap border border-slate-100 transition-all">Gratis</button>
                <button onclick="filterAcademy('paid', this)" class="filter-btn px-4 py-2 rounded-xl bg-white text-slate-400 text-[10px] font-black uppercase tracking-widest whitespace-nowrap border border-slate-100 transition-all">Berbayar</button>
                <button onclick="filterAcademy('newest', this)" class="filter-btn px-4 py-2 rounded-xl bg-white text-slate-400 text-[10px] font-black uppercase tracking-widest whitespace-nowrap border border-slate-100 transition-all">Terbaru</button>
            </div>
        </div>
    </div>

    <section class="px-5 py-6 pb-28 max-w-7xl mx-auto">
        <div id="akademi-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            <!-- Loading State -->
            <div class="bg-white p-5 rounded-[28px] shadow-sm border border-slate-100 animate-pulse flex md:flex-col gap-4">
                <div class="w-20 h-20 md:w-full md:h-40 bg-slate-100 rounded-2xl shrink-0"></div>
                <div class="flex-1">
                    <div class="h-4 bg-slate-100 rounded-md w-3/4 mb-2"></div>
                    <div class="h-3 bg-slate-100 rounded-md w-1/2 mb-4"></div>
                    <div class="h-6 bg-slate-100 rounded-full w-24 mt-auto"></div>
                </div>
            </div>
        </div>
    </section>

    <script>
        let allCourses = [];

        function renderCourses(courses) {
            const container = document.getElementById('akademi-container');
            container.innerHTML = '';
            
            if (courses.length === 0) {
                container.innerHTML = `
                    <div class="py-12 flex flex-col items-center justify-center text-slate-400">
                        <svg class="w-16 h-16 mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                        </svg>
                        <p class="text-sm font-bold uppercase tracking-widest">Tidak ada kursus ditemukan</p>
                    </div>
                `;
                return;
            }

            courses.forEach(course => {
                const div = document.createElement('div');
                div.className = 'bg-white p-4 rounded-[28px] shadow-sm border border-slate-100 flex md:flex-col gap-4 items-center md:items-start group active:scale-[0.98] transition-all fade-in';
                const badgeColor = course.type === 'paid' ? 'bg-amber-500' : 'bg-blue-600';
                const badgeText = course.type === 'paid' ? 'Berbayar' : 'Gratis';
                const priceText = course.type === 'paid' ? 
                                new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(course.price) : 
                                'Gratis';

                div.innerHTML = `
                    <div class="w-20 h-20 md:w-full md:h-44 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-300 text-3xl md:text-5xl font-black shrink-0 shadow-inner relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-br from-slate-100 to-transparent opacity-50"></div>
                        <span class="relative z-10">${course.title.charAt(0)}</span>
                        <div class="absolute bottom-2 right-2 md:bottom-4 md:right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                            <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-white shadow-lg flex items-center justify-center text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 md:w-5 md:h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                </svg>
                            </div>
                        </div>
                    </div>
                    <div class="flex-1 min-w-0 w-full flex flex-col">
                        <div class="flex items-center gap-2 mb-1.5">
                            <span class="text-[8px] md:text-[9px] font-black text-white ${badgeColor} px-2 py-0.5 rounded-md uppercase tracking-tighter">${badgeText}</span>
                            <span class="text-[8px] md:text-[9px] font-bold text-slate-400 uppercase tracking-widest">Kursus</span>
                        </div>
                        <h3 class="font-black text-sm md:text-base text-slate-800 truncate mb-1 leading-none tracking-tight">${course.title}</h3>
                        <p class="text-[11px] md:text-xs text-slate-400 line-clamp-2 leading-tight font-medium mb-4 flex-1">${course.short_desc || course.description || 'Pelajari materi ini sekarang'}</p>
                        <div class="flex justify-between items-center mt-auto">
                            <span class="text-xs md:text-sm font-black text-blue-900 tracking-tight">${priceText}</span>
                            <button onclick="showCourseDetail(${course.id})" class="text-[9px] md:text-[10px] font-black bg-slate-50 text-blue-600 border border-slate-100 px-4 py-2 rounded-full uppercase tracking-widest shadow-sm active:bg-blue-600 active:text-white transition-all">Detail</button>
                        </div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function filterAcademy(type, btn) {
            // Update UI buttons
            document.querySelectorAll('.filter-btn').forEach(b => {
                b.classList.remove('bg-blue-600', 'text-white', 'shadow-lg', 'shadow-blue-600/20');
                b.classList.add('bg-white', 'text-slate-400', 'border-slate-100');
            });
            btn.classList.add('bg-blue-600', 'text-white', 'shadow-lg', 'shadow-blue-600/20');
            btn.classList.remove('bg-white', 'text-slate-400', 'border-slate-100');

            let filtered = [...allCourses];
            if (type === 'free') {
                filtered = allCourses.filter(c => c.type === 'free');
            } else if (type === 'paid') {
                filtered = allCourses.filter(c => c.type === 'paid');
            } else if (type === 'newest') {
                filtered = [...allCourses].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
            }

            renderCourses(filtered);
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetch('/courses')
                .then(res => res.json())
                .then(courses => {
                    allCourses = courses;
                    renderCourses(courses);
                });

            // Search logic
            const searchInput = document.getElementById('academy-search');
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase();
                    const filtered = allCourses.filter(c => 
                        c.title.toLowerCase().includes(term) || 
                        (c.short_desc && c.short_desc.toLowerCase().includes(term))
                    );
                    renderCourses(filtered);
                });
            }
        });
    </script>
</div>