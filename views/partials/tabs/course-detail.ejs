<div id="view-course-detail" class="tab-content hidden bg-slate-50 min-h-screen">
    <section class="relative">
        <!-- Hero Background & Back Button -->
        <div class="h-64 bg-blue-900 w-full relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900"></div>
            <div class="absolute inset-0 opacity-20">
                <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white"></path>
                </svg>
            </div>
            
            <button onclick="switchTab('academy')" class="absolute top-6 left-5 z-20 w-10 h-10 bg-white/10 hover:bg-white/20 flex items-center justify-center rounded-full text-white backdrop-blur-md border border-white/10 transition-all active:scale-90">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
            </button>

            <div class="absolute bottom-12 left-6 right-6 z-10">
                <span id="detail-badge" class="inline-block px-3 py-1 bg-blue-600/90 backdrop-blur-md text-white text-[9px] font-black uppercase tracking-widest rounded-lg mb-3 shadow-lg"></span>
                <h1 id="detail-title" class="text-2xl font-black text-white leading-tight tracking-tight drop-shadow-md"></h1>
            </div>
        </div>

        <!-- Content Overlay -->
        <div class="px-5 -mt-8 relative z-20 pb-32">
            <div class="bg-white rounded-[32px] shadow-xl shadow-blue-900/5 p-6 border border-slate-100">
                <div id="detail-loading" class="animate-pulse space-y-4">
                    <div class="h-4 bg-slate-100 rounded-full w-1/4"></div>
                    <div class="h-8 bg-slate-100 rounded-2xl w-full"></div>
                    <div class="h-24 bg-slate-100 rounded-[24px] w-full"></div>
                </div>

                <div id="detail-content" class="hidden space-y-6">
                    <!-- Price & Stats -->
                    <div class="flex items-center justify-between border-b border-slate-50 pb-6">
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Harga Kursus</p>
                            <p id="detail-price" class="text-2xl font-black text-blue-900 tracking-tight"></p>
                        </div>
                        <div class="flex gap-3">
                            <div class="text-center">
                                <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-600 mb-1 border border-slate-100">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                    </svg>
                                </div>
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-tighter">Self-Paced</span>
                            </div>
                            <div class="text-center">
                                <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-600 mb-1 border border-slate-100">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75c0-1.245-.38-2.402-1.032-3.357m0 0a5.996 5.996 0 0 0-3.218 3.357c-.652.955-1.032 2.112-1.032 3.357m0 0v1.5h2.25" />
                                    </svg>
                                </div>
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-tighter">Sertifikat</span>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="space-y-3">
                        <h3 class="font-black text-slate-800 text-sm tracking-tight flex items-center gap-2">
                            <span class="w-1.5 h-4 bg-blue-600 rounded-full"></span>
                            Tentang Kursus
                        </h3>
                        <p id="detail-desc" class="text-slate-500 text-xs leading-relaxed font-medium"></p>
                    </div>

                    <!-- Syllabus/Curriculum Preview -->
                    <div class="space-y-4 pt-2">
                        <h3 class="font-black text-slate-800 text-sm tracking-tight flex items-center justify-between">
                            <span class="flex items-center gap-2">
                                <span class="w-1.5 h-4 bg-emerald-500 rounded-full"></span>
                                Kurikulum
                            </span>
                            <span id="detail-material-count" class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">0 Materi</span>
                        </h3>
                        <div id="detail-syllabus" class="space-y-3">
                            <!-- Populated via JS -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sticky Bottom Action Bar -->
        <div id="detail-action-bar" class="fixed bottom-[74px] left-0 right-0 bg-white/90 backdrop-blur-xl border-t border-slate-100 px-6 py-5 shadow-[0_-10px_30px_rgba(0,0,0,0.04)] hidden z-30 safe-area-inset-bottom" style="bottom: calc(74px + env(safe-area-inset-bottom));">
            <div class="mx-auto max-w-md md:max-w-2xl flex items-center gap-4">
                <button onclick="switchTab('academy')" class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-400 border border-slate-100 active:scale-90 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                    </svg>
                </button>
                <button id="btn-add-cart" class="flex-1 bg-blue-600 text-white h-14 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-blue-600/20 active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                    <span>Tambahkan ke Keranjang</span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                </button>
            </div>
        </div>
    </section>
</div>

<script>
    let currentCourse = null;

    async function showCourseDetail(id) {
        // Switch view
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        const view = document.getElementById('view-course-detail');
        view.classList.remove('hidden');
        
        // Show loading
        document.getElementById('detail-loading').classList.remove('hidden');
        document.getElementById('detail-content').classList.add('hidden');
        document.getElementById('detail-action-bar').classList.add('hidden');

        try {
            const res = await fetch('/courses/' + id);
            const course = await res.json();
            currentCourse = course;

            // Populate data
            document.getElementById('detail-title').innerText = course.title;
            document.getElementById('detail-desc').innerText = course.description || course.short_desc || 'Tidak ada deskripsi tersedia untuk kursus ini.';
            document.getElementById('detail-badge').innerText = course.type === 'paid' ? 'Premium Course' : 'Free Learning';
            
            // Render Syllabus
            const syllabus = document.getElementById('detail-syllabus');
            const materialCount = document.getElementById('detail-material-count');
            syllabus.innerHTML = '';
            
            if (course.materials && course.materials.length > 0) {
                materialCount.innerText = `${course.materials.length} Materi`;
                course.materials.forEach((m, idx) => {
                    const div = document.createElement('div');
                    div.className = 'flex items-center gap-4 p-3 rounded-2xl bg-slate-50 border border-slate-100';
                    div.innerHTML = `
                        <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center text-[10px] font-black text-slate-400 border border-slate-100 shadow-sm">${String(idx + 1).padStart(2, '0')}</div>
                        <p class="text-xs font-black text-slate-700 truncate">${m.title}</p>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-300 ml-auto">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                        </svg>
                    `;
                    syllabus.appendChild(div);
                });
            } else {
                materialCount.innerText = '0 Materi';
                syllabus.innerHTML = '<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center py-4">Materi belum diunggah</p>';
            }

            const btnAction = document.getElementById('btn-add-cart');
            if (course.type === 'paid') {
                document.getElementById('detail-price').innerText = new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(course.price);
                btnAction.querySelector('span').innerText = 'Beli Kursus Sekarang';
                btnAction.onclick = () => addToCart(course);
            } else {
                document.getElementById('detail-price').innerText = 'Gratis';
                btnAction.querySelector('span').innerText = 'Daftar Sekarang';
                btnAction.onclick = () => notify('Pendaftaran otomatis untuk kursus gratis akan segera hadir!', 'info');
            }

            // Show content
            document.getElementById('detail-loading').classList.add('hidden');
            document.getElementById('detail-content').classList.remove('hidden');
            document.getElementById('detail-action-bar').classList.remove('hidden');

        } catch (error) {
            console.error(error);
            notify('Gagal memuat data kursus', 'error');
            switchTab('academy');
        }
    }

    async function addToCart(course) {
        if (!isAuthenticated) {
            const confirmed = await confirmDialog('Login Diperlukan', 'Silakan login terlebih dahulu untuk mendaftar kursus ini.', 'Login Sekarang');
            if (confirmed) switchTab('login');
            return;
        }

        const btn = document.getElementById('btn-add-cart');
        const originalContent = btn.innerHTML;
        
        btn.disabled = true;
        btn.innerHTML = `<svg class="animate-spin h-5 w-5 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Memproses...`;

        try {
            const res = await fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    courseId: course.id,
                    title: course.title,
                    price: course.price
                })
            });
            const result = await res.json();
            
            if (result.success) {
                notify('Berhasil ditambahkan ke keranjang!', 'success');
                if(typeof updateCartCount === 'function') updateCartCount();
            } else {
                notify(result.message, 'error');
            }
        } catch (error) {
            console.error(error);
            notify('Gagal menambahkan ke keranjang', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalContent;
        }
    }
</script>