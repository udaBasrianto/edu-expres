<div id="view-profile" class="tab-content hidden bg-slate-50 min-h-screen">
    <!-- Modern Native Header -->
    <div class="sticky top-0 bg-white/90 backdrop-blur-xl z-30 px-5 pt-4 pb-3 shadow-[0_1px_3px_0_rgba(0,0,0,0.02)] border-b border-slate-100">
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-black text-slate-800 tracking-tight">Profil Saya</h2>
            <button class="w-9 h-9 rounded-full bg-slate-50 flex items-center justify-center text-slate-600 border border-slate-100 active:scale-90 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.062.511.092.773.092h7.128a2.25 2.25 0 0 0 2.25-2.25v-6.108c0-1.135-.804-2.118-1.926-2.307a9.749 9.749 0 0 0-2.922-.443M10.34 15.84a4.5 4.5 0 1 0 4.5-4.5m-4.5 4.5c.253.062.511.092.773.092h1.128M15.75 11.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                </svg>
            </button>
        </div>
    </div>

    <section class="px-5 py-6 pb-28">
        <% if (user) { %>
            <!-- Prominent User Card -->
            <div class="bg-white p-6 rounded-[32px] shadow-sm border border-slate-100 mb-8 relative overflow-hidden">
                <div class="absolute -right-10 -top-10 w-32 h-32 bg-blue-50 rounded-full blur-3xl opacity-50"></div>
                <div class="flex items-center gap-5 relative z-10">
                    <div class="w-20 h-20 rounded-full bg-blue-100 border-4 border-white shadow-md flex items-center justify-center overflow-hidden">
                        <img src="https://ui-avatars.com/api/?name=<%= user.name %>&background=1e3a8a&color=fff&size=128" class="w-full h-full object-cover" alt="Avatar">
                    </div>
                    <div class="flex-1 min-w-0">
                        <h3 class="font-black text-xl text-slate-800 leading-tight mb-1 truncate" id="profile-name-display"><%= user.name %></h3>
                        <p class="text-xs text-slate-400 font-medium mb-3 truncate"><%= user.email %></p>
                        <div class="flex items-center gap-2">
                            <span class="text-[9px] font-black text-white bg-blue-600 px-2 py-0.5 rounded-md uppercase tracking-tighter">Student</span>
                            <% if (user.role === 'admin') { %>
                                <span class="text-[9px] font-black text-white bg-indigo-600 px-2 py-0.5 rounded-md uppercase tracking-tighter">Admin</span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profile Menu (Settings Style) -->
            <div id="profile-menu" class="space-y-6">
                <!-- Group: Account -->
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-2 mb-3">Pengaturan Akun</p>
                    <div class="bg-white rounded-[28px] overflow-hidden border border-slate-100 shadow-sm">
                        <% if (user.role === 'admin') { %>
                            <a href="/admin" class="w-full flex items-center gap-4 p-4 hover:bg-slate-50 transition-colors border-b border-slate-50">
                                <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5z" />
                                    </svg>
                                </div>
                                <span class="flex-1 font-black text-sm text-slate-700">Panel Admin</span>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3 text-slate-300"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                            </a>
                        <% } %>
                        <button onclick="toggleEditProfile(true)" class="w-full flex items-center gap-4 p-4 hover:bg-slate-50 transition-colors border-b border-slate-50">
                            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                                </svg>
                            </div>
                            <span class="flex-1 font-black text-sm text-slate-700">Edit Profil & Keamanan</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3 text-slate-300"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                        </button>
                        <button onclick="togglePurchaseHistory(true)" class="w-full flex items-center gap-4 p-4 hover:bg-slate-50 transition-colors">
                            <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75-3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V14.25" />
                                </svg>
                            </div>
                            <span class="flex-1 font-black text-sm text-slate-700">Riwayat Pembelian</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3 text-slate-300"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                        </button>
                    </div>
                </div>

                <!-- Group: Support -->
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-2 mb-3">Dukungan</p>
                    <div class="bg-white rounded-[28px] overflow-hidden border border-slate-100 shadow-sm">
                        <button class="w-full flex items-center gap-4 p-4 hover:bg-slate-50 transition-colors border-b border-slate-50">
                            <div class="w-10 h-10 rounded-xl bg-orange-50 flex items-center justify-center text-orange-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                                </svg>
                            </div>
                            <span class="flex-1 font-black text-sm text-slate-700">Pusat Bantuan</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3 text-slate-300"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                        </button>
                        <button onclick="handleLogout(event)" class="w-full flex items-center gap-4 p-4 hover:bg-red-50 transition-colors group">
                            <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center text-red-600 group-hover:bg-red-100 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                                </svg>
                            </div>
                            <span class="flex-1 font-black text-sm text-red-600">Keluar Aplikasi</span>
                        </button>
                    </div>
                </div>
                
                <p class="text-center text-[10px] font-bold text-slate-300 uppercase tracking-[0.2em] pt-4">Edu HSI Express v1.0.0</p>
            </div>

            <!-- Purchase History (Hidden) -->
            <div id="purchase-history" class="hidden space-y-6">
                <div class="flex items-center gap-4 mb-6">
                    <button onclick="togglePurchaseHistory(false)" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 active:scale-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                    </button>
                    <h3 class="font-black text-lg text-slate-800 tracking-tight">Riwayat Pembelian</h3>
                </div>

                <!-- Tabs: Orders & Deposits -->
                <div class="flex gap-2 mb-6">
                    <button onclick="switchHistoryTab('orders')" id="btn-hist-orders" class="px-5 py-2.5 rounded-2xl bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest shadow-lg shadow-blue-600/20 transition-all">Pesanan</button>
                    <button onclick="switchHistoryTab('deposits')" id="btn-hist-deposits" class="px-5 py-2.5 rounded-2xl bg-white text-slate-400 text-[10px] font-black uppercase tracking-widest border border-slate-100 transition-all">Top Up</button>
                </div>

                <!-- Orders List -->
                <div id="hist-orders-list" class="space-y-4">
                    <% if (typeof orderHistory !== 'undefined' && orderHistory.length > 0) { %>
                        <% orderHistory.forEach(order => { %>
                            <div class="bg-white p-5 rounded-[28px] border border-slate-100 shadow-sm relative overflow-hidden">
                                <div class="flex items-center justify-between mb-4">
                                    <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">#ORD-<%= order.id %></span>
                                    <% 
                                        let statusClass = 'bg-slate-100 text-slate-500';
                                        if(order.status === 'paid') statusClass = 'bg-emerald-100 text-emerald-600';
                                        if(order.status === 'pending') statusClass = 'bg-amber-100 text-amber-600';
                                        if(order.status === 'cancelled') statusClass = 'bg-red-100 text-red-600';
                                    %>
                                    <span class="text-[8px] font-black px-2 py-0.5 rounded-md uppercase tracking-tighter <%= statusClass %>"><%= order.status %></span>
                                </div>
                                <div class="space-y-3 mb-4">
                                    <% order.items.forEach(item => { %>
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 font-black text-xs border border-slate-100">
                                                <%= (item.Product ? item.Product.title : (item.Course ? item.Course.title : 'ITM')).charAt(0) %>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-[11px] font-black text-slate-700 truncate"><%= item.Product ? item.Product.title : (item.Course ? item.Course.title : 'Item') %></p>
                                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Qty: <%= item.quantity %> • Rp <%= Number(item.price).toLocaleString('id-ID') %></p>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                                <div class="pt-4 border-t border-slate-50 flex items-center justify-between">
                                    <div>
                                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest leading-none mb-1">Total Bayar</p>
                                        <p class="text-sm font-black text-blue-900 tracking-tight leading-none">Rp <%= Number(order.total_amount).toLocaleString('id-ID') %></p>
                                    </div>
                                    <p class="text-[9px] font-bold text-slate-300 uppercase tracking-tighter"><%= new Date(order.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="bg-white p-10 rounded-[32px] border border-slate-100 text-center">
                            <p class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Belum Ada Pesanan</p>
                        </div>
                    <% } %>
                </div>

                <!-- Deposits List (Hidden Initially) -->
                <div id="hist-deposits-list" class="space-y-4 hidden">
                    <% if (typeof depositHistory !== 'undefined' && depositHistory.length > 0) { %>
                        <% depositHistory.forEach(dep => { %>
                            <div class="bg-white p-5 rounded-[28px] border border-slate-100 shadow-sm flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center justify-between mb-1">
                                        <p class="text-sm font-black text-slate-800 tracking-tight leading-none">Rp <%= Number(dep.amount).toLocaleString('id-ID') %></p>
                                        <% 
                                            let depStatusClass = 'bg-slate-100 text-slate-500';
                                            if(dep.status === 'approved') depStatusClass = 'bg-emerald-100 text-emerald-600';
                                            if(dep.status === 'pending') depStatusClass = 'bg-amber-100 text-amber-600';
                                            if(dep.status === 'rejected') depStatusClass = 'bg-red-100 text-red-600';
                                        %>
                                        <span class="text-[7px] font-black px-1.5 py-0.5 rounded-md uppercase tracking-tighter <%= depStatusClass %>"><%= dep.status %></span>
                                    </div>
                                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter truncate"><%= dep.BankAccount ? dep.BankAccount.bank_name : 'Transfer Bank' %> • <%= new Date(dep.createdAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short' }) %></p>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="bg-white p-10 rounded-[32px] border border-slate-100 text-center">
                            <p class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Belum Ada Top Up</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Edit Form (Hidden with Slide Animation) -->
            <div id="edit-profile-form" class="hidden space-y-6">
                <div class="flex items-center gap-4 mb-6">
                    <button onclick="toggleEditProfile(false)" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 active:scale-90 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                    </button>
                    <h3 class="font-black text-lg text-slate-800 tracking-tight">Edit Akun</h3>
                </div>

                <form onsubmit="handleUpdateProfile(event)" class="space-y-5">
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Nama Lengkap</label>
                        <input type="text" name="name" value="<%= user.name %>" 
                            class="w-full bg-white border border-slate-100 rounded-2xl py-4 px-5 text-sm font-black text-slate-800 focus:ring-4 focus:ring-blue-600/5 focus:border-blue-600 transition-all shadow-sm" required>
                    </div>
                    
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Alamat Email</label>
                        <input type="email" name="email" value="<%= user.email %>" 
                            class="w-full bg-white border border-slate-100 rounded-2xl py-4 px-5 text-sm font-black text-slate-800 focus:ring-4 focus:ring-blue-600/5 focus:border-blue-600 transition-all shadow-sm" required>
                    </div>
                    
                    <div class="pt-4 space-y-5">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-2">Keamanan Akun</p>
                        <div class="space-y-4">
                            <div class="space-y-1.5">
                                <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-2">Password Saat Ini</label>
                                <input type="password" name="current_password" placeholder="••••••••"
                                    class="w-full bg-white border border-slate-100 rounded-2xl py-4 px-5 text-sm font-black text-slate-800 focus:ring-4 focus:ring-blue-600/5 focus:border-blue-600 transition-all shadow-sm">
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-2">Password Baru</label>
                                <input type="password" name="new_password" placeholder="Minimal 6 karakter" minlength="6"
                                    class="w-full bg-white border border-slate-100 rounded-2xl py-4 px-5 text-sm font-black text-slate-800 focus:ring-4 focus:ring-blue-600/5 focus:border-blue-600 transition-all shadow-sm">
                            </div>
                        </div>
                    </div>

                    <div class="pt-6">
                        <button type="submit" class="w-full bg-blue-600 text-white font-black py-4 rounded-2xl uppercase tracking-widest shadow-xl shadow-blue-600/20 active:scale-95 transition-all">
                            Simpan Perubahan
                        </button>
                    </div>
                </form>
            </div>

        <% } else { %>
            <div class="bg-white p-10 rounded-[32px] shadow-sm border border-slate-100 text-center">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 border border-slate-100">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-slate-300">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                    </svg>
                </div>
                <h3 class="font-black text-slate-800 text-lg mb-2">Akses Terbatas</h3>
                <p class="text-xs text-slate-400 font-medium mb-8">Silakan masuk untuk mengakses fitur profil dan riwayat belajar Anda.</p>
                <a href="/login" class="inline-block bg-blue-600 text-white font-black px-10 py-4 rounded-2xl uppercase tracking-widest shadow-xl shadow-blue-600/20 active:scale-95 transition-all">Masuk Akun</a>
            </div>
        <% } %>
    </section>
</div>

<script>
function toggleEditProfile(show) {
    const menu = document.getElementById('profile-menu');
    const form = document.getElementById('edit-profile-form');
    const history = document.getElementById('purchase-history');
    
    if (show) {
        menu.classList.add('hidden');
        form.classList.remove('hidden');
        history.classList.add('hidden');
    } else {
        menu.classList.remove('hidden');
        form.classList.add('hidden');
    }
}

function togglePurchaseHistory(show) {
    const menu = document.getElementById('profile-menu');
    const history = document.getElementById('purchase-history');
    const form = document.getElementById('edit-profile-form');

    if (show) {
        menu.classList.add('hidden');
        history.classList.remove('hidden');
        form.classList.add('hidden');
    } else {
        menu.classList.remove('hidden');
        history.classList.add('hidden');
    }
}

function switchHistoryTab(tab) {
    const ordersList = document.getElementById('hist-orders-list');
    const depositsList = document.getElementById('hist-deposits-list');
    const btnOrders = document.getElementById('btn-hist-orders');
    const btnDeposits = document.getElementById('btn-hist-deposits');

    if (tab === 'orders') {
        ordersList.classList.remove('hidden');
        depositsList.classList.add('hidden');
        btnOrders.className = 'px-5 py-2.5 rounded-2xl bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest shadow-lg shadow-blue-600/20 transition-all';
        btnDeposits.className = 'px-5 py-2.5 rounded-2xl bg-white text-slate-400 text-[10px] font-black uppercase tracking-widest border border-slate-100 transition-all';
    } else {
        ordersList.classList.add('hidden');
        depositsList.classList.remove('hidden');
        btnOrders.className = 'px-5 py-2.5 rounded-2xl bg-white text-slate-400 text-[10px] font-black uppercase tracking-widest border border-slate-100 transition-all';
        btnDeposits.className = 'px-5 py-2.5 rounded-2xl bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest shadow-lg shadow-blue-600/20 transition-all';
    }
}

async function handleUpdateProfile(e) {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.innerText;
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Basic validation
    if (data.new_password && !data.current_password) {
        notify('Mohon masukkan password saat ini untuk mengubah password.', 'warning');
        return;
    }

    btn.disabled = true;
    btn.innerText = 'Menyimpan...';

    try {
        const res = await fetch('/profile/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await res.json();

        if (result.success) {
            notify(result.message, 'success');
            // Update display name and email
            document.getElementById('profile-name-display').innerText = data.name;
            const emailDisplay = document.querySelector('.bg-white p.text-xs.text-slate-400');
            if (emailDisplay) emailDisplay.innerText = data.email;
            // Clear password fields
            form.querySelector('input[name="current_password"]').value = '';
            form.querySelector('input[name="new_password"]').value = '';
            // Return to menu
            setTimeout(() => toggleEditProfile(false), 1500);
        } else {
            notify(result.message, 'error');
        }
    } catch (error) {
        console.error(error);
        notify('Terjadi kesalahan server', 'error');
    } finally {
        btn.disabled = false;
        btn.innerText = originalText;
    }
}
</script>
