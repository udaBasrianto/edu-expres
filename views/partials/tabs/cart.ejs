<div id="view-cart" class="tab-content hidden bg-slate-50 min-h-screen">
    <!-- Modern Native Header -->
    <div class="sticky top-0 bg-white/90 backdrop-blur-xl z-30 px-5 pt-4 pb-3 shadow-[0_1px_3px_0_rgba(0,0,0,0.02)] border-b border-slate-100">
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-black text-slate-800 tracking-tight">Keranjang</h2>
            <div id="cart-item-count-badge" class="bg-blue-50 px-3 py-1 rounded-full border border-blue-100 flex items-center gap-1.5">
                <span class="text-[10px] font-black text-blue-600 uppercase tracking-widest">0 Items</span>
            </div>
        </div>
    </div>

    <section class="px-5 pt-6 pb-[240px]">
        
        <!-- Loading Skeleton -->
        <div id="cart-loading" class="space-y-4 hidden">
            <div class="bg-white p-4 rounded-[28px] border border-slate-100 flex gap-4 animate-pulse">
                <div class="w-20 h-20 bg-slate-100 rounded-2xl"></div>
                <div class="flex-1 py-1">
                    <div class="h-4 bg-slate-100 rounded w-3/4 mb-2"></div>
                    <div class="h-3 bg-slate-100 rounded w-1/2"></div>
                </div>
            </div>
            <div class="bg-white p-4 rounded-[28px] border border-slate-100 flex gap-4 animate-pulse">
                <div class="w-20 h-20 bg-slate-100 rounded-2xl"></div>
                <div class="flex-1 py-1">
                    <div class="h-4 bg-slate-100 rounded w-3/4 mb-2"></div>
                    <div class="h-3 bg-slate-100 rounded w-1/2"></div>
                </div>
            </div>
        </div>

        <!-- Empty State -->
        <div id="cart-empty" class="bg-white p-10 rounded-[32px] shadow-sm border border-slate-100 text-center hidden mt-10">
            <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 border border-slate-100 relative">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-slate-300">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                </svg>
                <div class="absolute -top-1 -right-1 w-6 h-6 bg-red-50 rounded-full flex items-center justify-center text-red-400 font-black text-xs">?</div>
            </div>
            <h3 class="font-black text-slate-800 text-lg mb-2">Keranjang Kosong</h3>
            <p class="text-xs text-slate-400 font-medium mb-8">Anda belum menambahkan kursus atau produk digital apapun ke dalam keranjang.</p>
            <button onclick="switchTab('academy')" class="inline-block bg-blue-600 text-white font-black px-10 py-4 rounded-2xl uppercase tracking-widest shadow-xl shadow-blue-600/20 active:scale-95 transition-all">Cari Materi</button>
        </div>

        <!-- Items Container -->
        <div id="cart-items" class="space-y-4 hidden">
            <!-- Items injected here via loadCart() -->
        </div>

        <!-- Sticky Checkout Bar -->
        <div id="cart-summary" class="fixed bottom-[74px] left-0 right-0 bg-white/90 backdrop-blur-xl border-t border-slate-100 px-6 py-6 shadow-[0_-10px_30px_rgba(0,0,0,0.04)] hidden z-30 safe-area-inset-bottom" style="bottom: calc(74px + env(safe-area-inset-bottom));">
            <div class="mx-auto max-w-md md:max-w-2xl flex justify-between items-center gap-6">
                <div class="flex-1">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Pembayaran</p>
                    <p id="cart-total" class="text-xl font-black text-blue-900 tracking-tight leading-none">Rp 0</p>
                </div>
                <button onclick="handleCheckout()" class="flex-[1.5] bg-blue-600 text-white py-4 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-blue-600/20 hover:bg-blue-700 active:scale-95 transition-all flex items-center justify-center gap-2">
                    Checkout
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                    </svg>
                </button>
            </div>
        </div>
    </section>
</div>

<script>
    async function handleCheckout() {
        if (!confirm('Lanjutkan proses checkout untuk semua item?')) return;

        const btn = document.querySelector('#cart-summary button');
        const originalText = btn.innerHTML;
        btn.innerHTML = `
            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Proses...
        `;
        btn.disabled = true;

        try {
            const res = await fetch('/order/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await res.json();

            if (result.success) {
                notify(result.message, 'success');
                loadCart(); 
                if (typeof updateCartCount === 'function') updateCartCount();
                switchTab('home'); 
            } else {
                notify(result.message || 'Checkout gagal', 'error');
            }
        } catch (error) {
            console.error(error);
            notify('Terjadi kesalahan server', 'error');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    async function loadCart() {
        const loading = document.getElementById('cart-loading');
        const empty = document.getElementById('cart-empty');
        const items = document.getElementById('cart-items');
        const summary = document.getElementById('cart-summary');
        const badge = document.querySelector('#cart-item-count-badge span');
        
        loading.classList.remove('hidden');
        empty.classList.add('hidden');
        items.classList.add('hidden');
        summary.classList.add('hidden');

        try {
            const res = await fetch('/cart/items');
            const data = await res.json();
            const cart = data.items || [];
            
            loading.classList.add('hidden');
            badge.innerText = `${cart.length} Items`;

            if (cart.length === 0) {
                empty.classList.remove('hidden');
                return;
            }

            items.innerHTML = '';
            let total = 0;

            cart.forEach(item => {
                const product = item.Product;
                const course = item.Course;
                
                let name, price, imageHtml, typeBadge;

                if (product) {
                    name = product.name;
                    price = parseFloat(product.price || 0);
                    typeBadge = `<span class="text-[8px] font-black text-white bg-indigo-500 px-2 py-0.5 rounded-md uppercase tracking-tighter">Produk</span>`;
                    const imgSrc = product.image ? (product.image.startsWith('http') ? product.image : `/uploads/${product.image}`) : 'https://via.placeholder.com/150';
                    imageHtml = `<img src="${imgSrc}" alt="${name}" class="w-full h-full object-cover">`;
                } else if (course) {
                    name = course.title;
                    price = parseFloat(course.price || 0);
                    typeBadge = `<span class="text-[8px] font-black text-white bg-blue-600 px-2 py-0.5 rounded-md uppercase tracking-tighter">Kursus</span>`;
                    imageHtml = `
                        <div class="w-full h-full bg-blue-50 text-blue-600 flex items-center justify-center font-black text-3xl bg-gradient-to-br from-blue-50 to-blue-100">
                            ${course.title.charAt(0)}
                        </div>
                    `;
                } else {
                    return;
                }
                
                total += price;
                const div = document.createElement('div');
                div.className = 'bg-white p-4 rounded-[28px] shadow-sm border border-slate-100 flex justify-between items-center group transition-all active:scale-[0.98]';
                div.innerHTML = `
                    <div class="flex items-center gap-4 min-w-0">
                        <div class="w-20 h-20 bg-slate-100 rounded-[20px] overflow-hidden shrink-0 shadow-inner border border-slate-50">
                             ${imageHtml}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                ${typeBadge}
                                <span class="text-[8px] font-bold text-slate-400 uppercase tracking-widest">Premium</span>
                            </div>
                            <h3 class="font-black text-slate-800 text-sm truncate tracking-tight leading-none mb-2">${name}</h3>
                            <p class="text-blue-900 font-black text-sm tracking-tight leading-none">
                                ${new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(price)}
                            </p>
                        </div>
                    </div>
                    <button onclick="removeFromCart(${item.id})" class="w-10 h-10 rounded-full bg-red-50 text-red-500 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all shadow-sm active:scale-90" title="Hapus">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                    </button>
                `;
                items.appendChild(div);
            });

            document.getElementById('cart-total').innerText = new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(total);
            
            items.classList.remove('hidden');
            summary.classList.remove('hidden');
        } catch (error) {
            console.error('Failed to load cart:', error);
            loading.classList.add('hidden');
            empty.classList.remove('hidden');
        }
    }

    async function removeFromCart(id) {
        const confirmed = await confirmDialog('Hapus Item', 'Hapus item ini dari keranjang?', 'Ya, Hapus');
        if(!confirmed) return;
        
        try {
            const res = await fetch('/cart/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            const result = await res.json();
            
            if(result.success) {
                notify('Item dihapus', 'success');
                loadCart();
                if (typeof updateCartCount === 'function') updateCartCount();
            } else {
                notify('Gagal menghapus item', 'error');
            }
        } catch(e) {
            console.error(e);
            notify('Terjadi kesalahan server', 'error');
        }
    }
</script>
